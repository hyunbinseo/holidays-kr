{
	"name": "@hyunbinseo/holidays-kr",
	"description": "South Korea's national holidays, based on the official gazette",
	"version": "3.2026.0",
	"scripts": {
		"check": "tsc --noEmit",
		"prepack": "tsdown && publint",
		"preversion": "node --test",
		"version": "node src/write.ts && git add -A public",
		"postversion": "git push && git push --tags && node cli/postversion.ts",
		"format": "prettier --write ."
	},
	"devDependencies": {
		"@types/node": "^24.10.4",
		"prettier": "^3.7.4",
		"publint": "^0.3.16",
		"tsdown": "0.19.0-beta.2",
		"typescript": "^5.9.3",
		"valibot": "^1.2.0"
	},
	"type": "module",
	"exports": {
		".": {
			"require": "./dist/index.cjs",
			"import": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.cts",
	"files": [
		"dist"
	],
	"engines": {
		"node": ">=18"
	},
	"keywords": [
