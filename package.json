{
	"name": "@hyunbinseo/holidays-kr",
	"version": "4.2026.0",
	"description": "South Korea's national holidays, based on the official gazette",
	"keywords": [
		"Korean",
		"holidays",
		"공휴일",
		"대한민국",
		"한국"
	],
	"homepage": "https://github.com/hyunbinseo/holidays-kr#readme",
	"bugs": {
		"url": "https://github.com/hyunbinseo/holidays-kr/issues"
	},
	"license": "MIT",
	"author": "Hyunbin Seo",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/hyunbinseo/holidays-kr.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"imports": {
		"#cli/*": "./cli/*",
		"#src/*": "./src/*"
	},
	"exports": {
		".": "./dist/index.js",
		"./package.json": "./package.json"
	},
	"scripts": {
		"prepack": "tsdown",
		"preversion": "vitest run",
		"version": "node --env-file-if-exists=.env cli/write/all.ts && git add -A public",
		"postversion": "git push && git push --tags && node cli/postversion.ts",
		"check": "tsc --noEmit",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"test": "vitest"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.2",
		"@types/node": "^24.12.2",
		"oxfmt": "^0.44.0",
		"oxlint": "^1.59.0",
		"publint": "^0.3.18",
		"tsdown": "^0.21.7",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
